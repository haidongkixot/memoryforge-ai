generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          String    @default("user")
  status        String    @default("active")
  statusNote    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      AuthSession[]
  gameSessions  GameSession[]
  achievements  UserAchievement[]
  xpLedger      XpLedger[]
  streaks       Streak[]
  dailyStats    DailyStat[]
  memoryProfiles MemoryProfile[]
  coachMessages CoachMessage[]
  trainingPlans TrainingPlan[]
  analyticsEvents AnalyticsEvent[]
  activityLogs  ActivityLog[]
  chapterProgress UserChapterProgress[]
  plan            String            @default("free")
  subscriptions   Subscription[]
  referralCode     ReferralCode?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model AuthSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
}

model Game {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  category    String
  difficulty  String        @default("beginner")
  description String        @db.Text
  benefits    String[]
  rules       String[]
  gameType    String        @default("memory")
  gridSize    Int           @default(4)
  timeLimit   Int           @default(60)
  maxLevel    Int           @default(10)
  imageUrl    String?
  isActive    Boolean       @default(true)
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  gameSessions GameSession[]
  contents     GameContent[]
  @@index([category])
  @@index([isActive, sortOrder])
}

model GameContent {
  id          String   @id @default(cuid())
  gameId      String
  contentType String   // 'word_list' | 'word_pair' | 'face_data' | 'custom'
  content     Json     // flexible: words array, pair objects, face objects
  difficulty  String   @default("beginner")
  label       String   @default("Default")  // "Pack 1", "Animals Theme", etc.
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  game        Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([gameId])
  @@index([contentType])
}

model GameSession {
  id          String   @id @default(cuid())
  userId      String
  gameId      String
  score       Int      @default(0)
  level       Int      @default(1)
  accuracy    Float    @default(0)
  duration    Int      @default(0)
  movesCount  Int      @default(0)
  completedAt DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  game        Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)
  @@index([userId, gameId, completedAt])
}

model UserAchievement {
  id          String   @id @default(cuid())
  userId      String
  achievement String
  unlockedAt  DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, achievement])
  @@index([userId])
}

// ── XP & Gamification ──

model XpLedger {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  reason    String
  metadata  Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, createdAt])
}

model Streak {
  id            String   @id @default(cuid())
  userId        String
  type          String   @default("daily_play")
  currentCount  Int      @default(0)
  longestCount  Int      @default(0)
  lastActiveAt  DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, type])
}

model DailyStat {
  id             String   @id @default(cuid())
  userId         String
  date           DateTime @db.Date
  gamesPlayed    Int      @default(0)
  totalScore     Int      @default(0)
  totalXp        Int      @default(0)
  avgAccuracy    Float    @default(0)
  bestAccuracy   Float    @default(0)
  totalDuration  Int      @default(0)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, date])
}

// ── Memory Training ──

model MemoryProfile {
  id               String   @id @default(cuid())
  userId           String
  memoryType       String
  strengthScore    Float    @default(50)
  lastAssessedAt   DateTime @default(now())
  improvementRate  Float    @default(0)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, memoryType])
}

model MemoryTechnique {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  category    String
  description String   @db.Text
  steps       String[]
  difficulty  String   @default("beginner")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  @@index([category])
}

model TrainingPlan {
  id          String              @id @default(cuid())
  userId      String
  name        String
  goal        String
  status      String              @default("active")
  startDate   DateTime            @default(now())
  endDate     DateTime?
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       TrainingPlanItem[]
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  @@index([userId, status])
}

model TrainingPlanItem {
  id             String       @id @default(cuid())
  planId         String
  dayNumber      Int
  gameId         String?
  techniqueSlug  String?
  targetScore    Int?
  completed      Boolean      @default(false)
  completedAt    DateTime?
  plan           TrainingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  @@index([planId, dayNumber])
}

// ── AI Coach ──

model CoachMessage {
  id        String   @id @default(cuid())
  userId    String
  role      String
  content   String   @db.Text
  context   Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, createdAt])
}

model CoachInsight {
  id          String   @id @default(cuid())
  type        String
  title       String
  description String   @db.Text
  conditions  Json
  priority    Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  @@index([type, isActive])
}

// ── Analytics & Logging ──

model AnalyticsEvent {
  id         String   @id @default(cuid())
  userId     String?
  event      String
  category   String
  properties Json?
  sessionId  String?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  @@index([event, createdAt])
  @@index([userId, createdAt])
  @@index([category, createdAt])
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ip        String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  @@index([userId, createdAt])
  @@index([action, createdAt])
}

model SystemLog {
  id        String   @id @default(cuid())
  level     String
  message   String   @db.Text
  context   Json?
  source    String?
  createdAt DateTime @default(now())
  @@index([level, createdAt])
  @@index([source, createdAt])
}

model AppConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  label     String?
  updatedAt DateTime @updatedAt
}

// ── AI Generation ──

// ── Academy ──

model AcademyChapter {
  id            String   @id @default(cuid())
  slug          String   @unique
  title         String
  body          String   @db.Text
  category      String
  sortOrder     Int      @default(0)
  keyTakeaways  String[]
  minPlanSlug   String   @default("free")
  quizData      Json?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  progress      UserChapterProgress[]

  @@index([category])
  @@index([isActive, sortOrder])
}

model UserChapterProgress {
  id          String   @id @default(cuid())
  userId      String
  chapterId   String
  completed   Boolean  @default(false)
  quizScore   Int?
  quizAnswers Json?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapter     AcademyChapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([userId, chapterId])
  @@index([userId])
}

model AIGenerationLog {
  id           String   @id @default(cuid())
  contentType  String
  action       String   @default("generate")
  prompt       String   @db.Text
  result       Json
  model        String   @default("gpt-4o-mini")
  tokensUsed   Int?
  durationMs   Int?
  status       String   @default("success")
  error        String?  @db.Text
  adminId      String
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([contentType])
  @@index([adminId])
  @@index([createdAt])
}

model AIConfig {
  id           String   @id @default(cuid())
  contentType  String   @unique
  model        String   @default("gpt-4o-mini")
  temperature  Float    @default(0.9)
  maxTokens    Int      @default(1000)
  systemPrompt String   @db.Text
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ReferralCode {
  id        String           @id @default(cuid())
  userId    String           @unique
  code      String           @unique
  clicks    Int              @default(0)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  referrals ReferralReward[]

  @@index([code])
}

model ReferralReward {
  id             String       @id @default(cuid())
  referrerId     String
  referredUserId String       @unique
  referralCodeId String
  activatedAt    DateTime?
  rewardGranted  Boolean      @default(false)
  rewardType     String       @default("free_month")
  createdAt      DateTime     @default(now())
  referralCode   ReferralCode @relation(fields: [referralCodeId], references: [id])

  @@index([referrerId])
}

// ─── Blog ────────────────────────────────────────────────────

model BlogPost {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String?   @db.Text
  body        String    @db.Text
  coverImage  String?
  tags        String[]
  status      String    @default("draft")
  authorId    String?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status])
  @@index([publishedAt])
}

model EmailSubscriber {
  id           String    @id @default(cuid())
  email        String    @unique
  source       String    @default("landing_page")
  status       String    @default("active")
  subscribedAt DateTime  @default(now())
  unsubAt      DateTime?

  @@index([status])
}

// ─── Plans & Subscriptions ───────────────────────────────

model Plan {
  id            String         @id @default(cuid())
  slug          String         @unique
  name          String
  priceMonthly  Float          @default(0)
  priceYearly   Float          @default(0)
  features      Json?
  isActive      Boolean        @default(true)
  sortOrder     Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  subscriptions Subscription[]
}

model Subscription {
  id                 String    @id @default(cuid())
  userId             String
  planId             String
  status             String    @default("active")
  period             String    @default("monthly")
  stripeSubId        String?   @unique
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  startDate          DateTime  @default(now())
  endDate            DateTime?
  cancelledAt        DateTime?
  createdAt          DateTime  @default(now())
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan               Plan      @relation(fields: [planId], references: [id])

  @@index([userId])
}